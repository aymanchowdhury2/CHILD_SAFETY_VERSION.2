#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <Adafruit_MLX90614.h>

// --- WiFi Configuration ---
const char* ssid = "CHILD SAFETY";
const char* password = "234555444";

IPAddress local_IP(192, 168, 0, 9);
IPAddress gateway(192, 168, 0, 1);
IPAddress subnet(255, 255, 255, 0);

WebServer server(80);
Adafruit_MLX90614 mlx = Adafruit_MLX90614();

// --- Pin Definitions ---
#define BTN_DANGER 4   // Danger Button
#define PIN_WATER  5   // Water Probes
#define PIN_FIRE   23  // Fire Loop

void handleRoot() {
  float bodyTemp = mlx.readObjectTempC();
  String status = "SYSTEM STABLE";
  String color = "#00FF00"; 

  // Priority Alert Logic
  if (digitalRead(BTN_DANGER) == HIGH) { 
    status = "BABY IN DANGER!"; color = "#FF0000"; 
  } else if (digitalRead(PIN_WATER) == HIGH) { 
    status = "BABY UNDER WATER!"; color = "#0000FF"; 
  } else if (digitalRead(PIN_FIRE) == LOW) { 
    status = "BABY ON FIRE!"; color = "#FFA500"; 
  } else if (bodyTemp > 37.8) {
    status = "HIGH FEVER ALERT!"; color = "#FF4500";
  }

  // Web Interface
  String h = "<html><head><meta name='viewport' content='width=device-width, initial-scale=1'>";
  h += "<style>body{background:#000;color:#fff;font-family:sans-serif;text-align:center;padding:20px;}";
  h += ".card{border:2px solid #333;padding:30px;border-radius:25px;background:#111;}";
  h += ".status{font-size:32px;font-weight:bold;color:" + color + ";margin:20px 0;}";
  h += ".temp{font-size:24px;color:#0f0;}</style><meta http-equiv='refresh' content='2'></head><body>";
  h += "<div class='card'><h1>Child Safety Monitor</h1><hr>";
  h += "<div class='status'>" + status + "</div>";
  h += "<p class='temp'>MLX90614 Temp: " + String(bodyTemp) + " &deg;C</p></div>";
  h += "</body></html>";
  
  server.send(200, "text/html", h);
}

void setup() {
  // Communication with MLX90614 on Pin 21 (Data) and Pin 22 (Clock)
  Wire.begin(21, 22); 
  mlx.begin();
  
  pinMode(BTN_DANGER, INPUT_PULLDOWN);
  pinMode(PIN_WATER, INPUT_PULLDOWN);
  pinMode(PIN_FIRE, INPUT_PULLUP); 

  WiFi.softAP(ssid, password);
  WiFi.softAPConfig(local_IP, gateway, subnet);
  server.on("/", handleRoot);
  server.begin();
}

void loop() {
  server.handleClient();
}
